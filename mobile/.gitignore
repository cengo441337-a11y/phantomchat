# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Cross-compiled native libs staged by scripts/build-android.sh
/android/app/src/main/jniLibs/

# Rust wrapper crate build cache (Cargo.lock IS checked in per cargo guidance
# for binary-shaped crates — this cdylib ships as the Android JNI lib).
/rust/target/

# Android release-signing material — NEVER commit these.
# Generated keystore lives outside the repo (~/.android/phantomchat-release.jks);
# key.properties holds the path + password and must stay local-only.
# The .template file IS tracked so contributors can see the expected schema.
/android/key.properties
**/*.keystore
**/*.jks
