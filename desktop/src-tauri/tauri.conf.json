{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Argos",
  "version": "3.1.0",
  "identifier": "de.dc-infosec.phantomchat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Argos",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0A0A0F"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: asset: http://asset.localhost; media-src 'self' blob: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost; frame-src 'none'; object-src 'none'; base-uri 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOWNLOAD/PhantomChat/**",
          "$HOME/Downloads/PhantomChat/**",
          "$APPDATA/voice/**",
          "$APPLOCALDATA/voice/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Encrypted corporate messenger",
    "longDescription": "PhantomChat \u2014 end-to-end encrypted messenger with stealth-tag scanning, double-ratchet sessions and PQXDH-hybrid envelopes.",
    "windows": {
      "signCommand": "cmd /C ..\\..\\scripts\\sign-windows-v2.cmd %1"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updates.dc-infosec.de/phantomchat/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyRjkyREVBODg5NUEzMjYKUldRbW81V0k2aTM1d2dGMmRxUlFvQ01OeHVzTDUyNjFkeU5kY3RtWkg2WnIrdWs3YTE1YXg1MDIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
