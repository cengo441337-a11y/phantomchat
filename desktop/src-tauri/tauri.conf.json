{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PhantomChat",
  "version": "0.1.0",
  "identifier": "de.dc-infosec.phantomchat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PhantomChat",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0A0A0F"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DOWNLOAD/PhantomChat/**",
          "$HOME/Downloads/PhantomChat/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Encrypted corporate messenger",
    "longDescription": "PhantomChat \u2014 end-to-end encrypted messenger with stealth-tag scanning, double-ratchet sessions and PQXDH-hybrid envelopes.",
    "windows": {
      "signCommand": "\"%PHANTOMCHAT_SIGNTOOL%\" sign /f \"%PHANTOMCHAT_PFX_PATH%\" /p \"%PHANTOMCHAT_PFX_PASSWORD%\" /fd SHA256 /td SHA256 /tr http://timestamp.digicert.com /d PhantomChat /du https://dc-infosec.de/phantomchat %1"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updates.dc-infosec.de/phantomchat/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4NDIwNjEyRUZFMDgwMUYKUldRZmdPRHZFZ1pDNkZNMjA3Wmo3Z3hucXhSSHJEWCtqZFRHQkloRTRRRDJ6REU4VlFtUkYrMjkK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
